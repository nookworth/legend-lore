# Your own Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# AssemblyAI — only needed for full pipeline (steps 1-3, transcription)
# https://www.assemblyai.com
ASSEMBLYAI_API_KEY=

# Discord recap channel ID — required for posting recaps as a bot message.
# The bot needs Send Messages permission in this channel.
DISCORD_RECAP_CHANNEL_ID=

# Discord bot token — required for text chat ingestion (--skip-text-chat to disable)
# Create a bot at https://discord.com/developers/applications and enable the
# "Message Content" privileged intent. Invite it to the guild with View Channel
# and Read Message History permissions.
DISCORD_BOT_TOKEN=

# Optional: comma-separated list of channel IDs to scrape for text chat.
# If unset, all text-capable channels in the guild are swept (uses guild ID from
# audio/info.txt). Set this as an optimization if you know which channels to use.
DISCORD_TEXT_CHANNEL_IDS=

# Google Cloud — use the shared project and buckets (pre-filled below)
GOOGLE_CLOUD_PROJECT=legend-lore
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./judge-key.json  # path to the downloaded judge-key.json

# Shared GCS buckets (pre-filled — no need to create your own)
GCS_BUCKET_AUDIO=legend-lore-audio
GCS_BUCKET_VIDEOS=legend-lore-video
GCS_BUCKET_ASSETS=legend-lore-assets

# Group namespace (pre-filled)
GROUP_ID=1
