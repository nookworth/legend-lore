# Gemini (required)
GEMINI_API_KEY=

# AssemblyAI — required only if running from raw audio (steps 1-3)
ASSEMBLYAI_API_KEY=

# Discord — required for delivery (step 10); omit or use --skip-deliver to skip
DISCORD_WEBHOOK_URL=

# Google Cloud (required)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=  # path to service account JSON (local dev only)

# GCS bucket names
GCS_BUCKET_AUDIO=
GCS_BUCKET_VIDEOS=
GCS_BUCKET_ASSETS=

# Group / session namespacing
GROUP_ID=
